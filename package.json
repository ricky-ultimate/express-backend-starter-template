{
    "name": "express-backend-starter-template",
    "version": "1.0.0",
    "description": "Express.js backend starter template with TypeScript, Prisma, and PostgreSQL",
    "main": "index.js",
    "scripts": {
        "start": "npm run build && node ./dist/src/index.js",
        "build": "tsc",
        "prebuild": "prisma generate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:pull": "prisma db pull",
        "db:migrate": "prisma migrate dev",
        "dev": "ts-node-dev ./src/index.ts --watch ./*/**"
    },
    "keywords": [
        "express",
        "typescript",
        "prisma",
        "postgresql",
        "template"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "morgan": "^1.10.1",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.0",
        "prisma": "^7.8.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.3"
    }
}
